{
  "name": "@moc-global/eslint-config",
  "version": "1.0.0",
  "description": "Shared, company-wide ESLint flat config for Node.js, NestJS, React, and Vue projects — with an interactive installer.",
  "keywords": [
    "eslint",
    "eslint-config",
    "eslintconfig",
    "flat-config",
    "typescript",
    "react",
    "vue",
    "nestjs",
    "prettier",
    "shareable-config"
  ],
  "author": "Dmytro Vakulenko",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": "^22.21.0 || >=24.10.0"
  },
  "bin": {
    "moc-eslint": "./src/cli/index.mjs"
  },
  "main": "./src/index.mjs",
  "exports": {
    ".": "./src/index.mjs",
    "./node": "./src/node.eslint.mjs",
    "./react": "./src/react.eslint.mjs",
    "./vue": "./src/vue.eslint.mjs",
    "./nest": "./src/nest.eslint.mjs",
    "./vitest": "./src/vitest.eslint.mjs",
    "./jest": "./src/jest.eslint.mjs",
    "./zod": "./src/zod.eslint.mjs",
    "./i18n": "./src/i18n.eslint.mjs",
    "./tailwind": "./src/tailwind.eslint.mjs",
    "./stacks": "./src/cli/stacks.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "format": "prettier . --write",
    "pack:check": "npm pack --dry-run"
  },
  "dependencies": {
    "@dword-design/eslint-plugin-import-alias": "^8.1.8",
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vitest/eslint-plugin": "^1.6.16",
    "eslint-config-naming": "^1.9.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-depend": "^1.5.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-import-zod": "^1.2.1",
    "eslint-plugin-jsdoc": "^63.0.2",
    "eslint-plugin-lintlord": "^1.2.0",
    "eslint-plugin-n": "^18.1.0",
    "eslint-plugin-no-barrel-files": "^1.3.1",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^65.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-zod": "^4.7.0",
    "globals": "^17.5.0",
    "json5": "^2.2.3",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.1"
  },
  "peerDependencies": {
    "@darraghor/eslint-plugin-nestjs-typed": "^7.1.31",
    "eslint": "^9.24.0 || ^10.0.0",
    "eslint-plugin-better-tailwindcss": "^4.6.0",
    "eslint-plugin-i18next": "^6.1.4",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "^19.0.0 || ^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-vue": "^10.9.2",
    "typescript": ">=5.0.0",
    "vue-eslint-parser": "^10.4.1"
  },
  "peerDependenciesMeta": {
    "@darraghor/eslint-plugin-nestjs-typed": { "optional": true },
    "eslint-plugin-better-tailwindcss": { "optional": true },
    "eslint-plugin-i18next": { "optional": true },
    "eslint-plugin-jest": { "optional": true },
    "eslint-plugin-react": { "optional": true },
    "eslint-plugin-react-compiler": { "optional": true },
    "eslint-plugin-react-hooks": { "optional": true },
    "eslint-plugin-react-refresh": { "optional": true },
    "eslint-plugin-vue": { "optional": true },
    "typescript": { "optional": true },
    "vue-eslint-parser": { "optional": true }
  },
  "devDependencies": {
    "@darraghor/eslint-plugin-nestjs-typed": "^7.1.31",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-plugin-better-tailwindcss": "^4.6.0",
    "eslint-plugin-i18next": "^6.1.4",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-vue": "^10.9.2",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.3",
    "vitest": "^4.1.5",
    "vue-eslint-parser": "^10.4.1"
  },
  "overrides": {
    "zod-validation-error": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/moc-global/eslint-config.git"
  }
}
